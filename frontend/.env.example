# Base URL of the backend API (must include the /api suffix).
# Local:      http://localhost:5000/api
# Production: https://<your-backend-project>.vercel.app/api
VITE_API_URL=http://localhost:5000/api

# Google OAuth client ID for "Continue with Google" (not secret; exposed in the
# client bundle). Must match the backend's GOOGLE_CLIENT_ID. Add your site's
# origin under "Authorized JavaScript origins" in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=
