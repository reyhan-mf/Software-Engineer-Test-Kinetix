PORT=5000
MONGO_URI=mongodb://localhost:27017/blog_platform
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
NODE_ENV=development

# CORS: URL of the deployed frontend (no trailing slash)
# Local:      http://localhost:5173
# Production: https://<your-frontend-project>.vercel.app
CLIENT_URL=http://localhost:5173

# Image storage. Leave blank locally to fall back to ./uploads on disk.
# In production this is injected automatically when you connect a Vercel Blob
# store to the backend project (Storage tab -> Create / Connect Blob store).
BLOB_READ_WRITE_TOKEN=

# Google OAuth client ID (same value as the frontend's VITE_GOOGLE_CLIENT_ID).
# Used to verify the Google ID token's signature and audience. Not secret.
# Create at https://console.cloud.google.com -> APIs & Services -> Credentials.
GOOGLE_CLIENT_ID=
